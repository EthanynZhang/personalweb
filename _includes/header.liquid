{% assign site_root = site.url | append: site.baseurl %}

<header class="academic-site-header">
  <nav id="navbar" class="navbar navbar-expand-md academic-navbar" role="navigation" aria-label="Main navigation">
    <div class="academic-nav-container">
      <a class="academic-brand" href="{{ site_root }}/" aria-label="Zhang Yining Ethan homepage">
        <span class="academic-brand-name">Zhang Yining Ethan</span>
        <span class="academic-brand-subtitle">Education Technology / GenAI / XR / L2 Learning</span>
      </a>

      <button
        class="navbar-toggler collapsed navbar-toggler-main academic-navbar-toggler"
        type="button"
        data-nav-toggle="navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse navbar-collapse-main academic-navbar-collapse" id="navbarNav">
        <ul class="navbar-nav navbar-menu-list academic-menu">
          {% for site_page in site.pages %}
            {% if site_page.permalink == '/' %} {% assign about_title = site_page.title %} {% endif %}
          {% endfor %}

          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ site_root }}/">
              About
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for nav_page in sorted_pages %}
            {% if nav_page.nav and nav_page.autogen == null %}
              {% assign parent_link = nav_page.permalink | remove: 'index.html' %}
              <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                {%- if nav_page.permalink contains '://' -%}
                  {%- assign nav_url = nav_page.permalink -%}
                {%- elsif nav_page.permalink contains '/blog/' -%}
                  {%- assign nav_url = site_root | append: '/blog/' -%}
                {%- else -%}
                  {%- assign nav_url = site_root | append: nav_page.url -%}
                {%- endif %}
                <a class="nav-link" href="{{ nav_url }}">
                  {{- nav_page.title }}
                  {% if page.url contains nav_page.url %}
                    <span class="sr-only">(current)</span>
                  {% endif %}
                </a>
              </li>
            {% endif %}
          {% endfor %}

          {% if site.search_enabled %}
            <li class="nav-item academic-search-item">
              <button id="search-toggle" class="academic-search-button" type="button" title="Search" aria-label="Open search">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>

  {% if site.enable_progressbar %}
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
